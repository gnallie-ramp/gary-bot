# ══════════════════════════════════════════════════════════════════════════════
# Gary Bot — Environment Configuration
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── Owner Identity ────────────────────────────────────────────────────────────
# Your full name EXACTLY as it appears in Salesforce (used in all queries)
OWNER_NAME=Gregory Nallie
# Your first name (used in email sign-offs and Claude prompts)
OWNER_FIRST_NAME=Greg
# Your Slack user ID (click your profile → ⋮ → Copy member ID)
OWNER_SLACK_ID=U06DAFU4YRG
# Your ChiliPiper booking link (used in email CTAs)
BOOKING_LINK=https://ramp-com.chilipiper.com/me/gregory-nallie/ramp
# Your display timezone (job scheduling always uses US/Pacific)
DISPLAY_TIMEZONE=US/Eastern

# ── Slack App ─────────────────────────────────────────────────────────────────
# Create a Slack app from the manifest (see SETUP.md), then install to workspace
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Get your API key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Gmail ──────────────────────────────────────────────────────────────────────
# Your Ramp email address (used for email context and Gong call matching)
GMAIL_ADDRESS=you@ramp.com
